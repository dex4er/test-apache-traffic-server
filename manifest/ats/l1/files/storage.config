# L1 is a RAM-only cache tier.
# ATS requires at least one valid storage entry or it disables the entire cache
# (including the RAM cache). We point storage at /var/cache/ats which is backed
# by a Kubernetes emptyDir with medium: Memory (tmpfs) — pure RAM, no disk I/O.
# WARNING: cache is lost on every pod restart by design.

/var/cache/ats 128M
