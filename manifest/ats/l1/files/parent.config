# Routes requests for per-pod origins through the L2 cache tier.
# L1 applies its remap rules first (resolving /podinfo-0 and /podinfo-1 to their
# headless-service hostnames), then parent.config directs misses to L2 instead
# of going straight to origin.
#
# Both L2 pods are listed explicitly using their stable StatefulSet DNS names
# (headless service required). Semicolon-separated parents with round_robin=false
# means: use l2-0 as primary, fail over to l2-1 when l2-0 is marked down.
# ATS marks a parent down after fail_threshold consecutive failures and retries
# it after retry_time seconds (both configured in records.yaml).
#
# go_direct=false: L1 never bypasses L2 for these destinations.

dest_domain=backend.backend.svc.cluster.local parent="apache-traffic-server-l2-0.apache-traffic-server-l2.ats.svc.cluster.local:8080;apache-traffic-server-l2-1.apache-traffic-server-l2.ats.svc.cluster.local:8080" round_robin=false go_direct=false
