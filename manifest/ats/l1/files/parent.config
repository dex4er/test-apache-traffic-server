# Routes requests for per-pod origins through the L2 cache tier.
# L1 applies its remap rules first (resolving /podinfo-0 and /podinfo-1 to their
# headless-service hostnames), then parent.config directs misses to L2 instead
# of going straight to origin.
#
# go_direct=false: L1 never bypasses L2 for these destinations.
# round_robin=false: single parent, no load-balancing needed.

dest_domain=podinfo-0.podinfo.podinfo.svc.cluster.local parent="apache-traffic-server-l2.ats.svc.cluster.local:8080" round_robin=false go_direct=false

dest_domain=podinfo-1.podinfo.podinfo.svc.cluster.local parent="apache-traffic-server-l2.ats.svc.cluster.local:8080" round_robin=false go_direct=false
