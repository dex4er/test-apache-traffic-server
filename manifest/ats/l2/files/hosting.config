# Assign per-pod origins to dedicated disk volumes for full cache isolation.
# L2 only receives traffic for podinfo-0 and podinfo-1 (from L1 via parent.config).
#
# ATS requires at least one volume entry for Generic Hostnames or it disables
# disk cache entirely. hostname=* satisfies this requirement. In practice, L2
# never receives catch-all traffic (L1 routes it directly to origin).

# Assign backend origin to volume 1.
hostname=backend.backend.svc.cluster.local volume=1

# Required catch-all: prevents ATS from disabling disk cache entirely.
hostname=* volume=1
