# Fixed TTL for per-pod origins cached on L2's disk.
# L2 TTL must be longer than L1's TTL (60s) so that when L1's RAM entry expires
# and L1 asks L2, L2 still has a fresh copy and does not need to contact origin
# on every revalidation cycle. 120s = 2× L1 TTL.
# ttl-in-cache value must be an integer number of seconds (not "60s" or "0:1:0").

dest_domain=podinfo-0.podinfo.podinfo.svc.cluster.local ttl-in-cache=120

dest_domain=podinfo-1.podinfo.podinfo.svc.cluster.local ttl-in-cache=120

# Catch-all: force 120-second TTL for any other origin that returns no cache
# headers. Applies when the specific dest_domain rules above do not match
# (e.g. if ATS sees the request URL with a non-standard port).
url_regex=.* ttl-in-cache=120
