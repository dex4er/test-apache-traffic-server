# Each line describes one physical storage area for the disk cache.
# Syntax: <path> <size>[M|G] [volume=<N>]
# The size specified here must be larger than the logical volume size in
# volume.config — ATS needs extra space for per-stripe metadata.
# Storage size 256M gives headroom for volume size 128 (integer MB, no suffix).

# Volume 1 — used for podinfo-0 traffic (see hosting.config).
/var/cache/ats/0 256M volume=1

# Volume 2 — used for podinfo-1 traffic (see hosting.config).
/var/cache/ats/1 256M volume=2
