header_rewrite.so /opt/etc/trafficserver/header_rewrite.config

# xdebug.so: adds X-Cache header to the response when the upstream (L1) sends
# X-Debug: X-Cache in the request. All debug headers disabled by default.
xdebug.so --enable=x-cache,x-remap

# background_fetch.so: serves stale objects immediately and revalidates in the
# background. Particularly useful on L2 where disk I/O may be slower.
background_fetch.so
