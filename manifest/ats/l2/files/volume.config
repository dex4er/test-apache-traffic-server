# Logical volume definitions for the disk cache.
# Syntax: volume=<N> scheme=http|https size=<MB>
# WARNING: changing size values wipes the disk cache on restart.
# size= accepts only plain integers (megabytes) — no "M" suffix, no "%" value.
# Percentage values are evaluated against the actual filesystem size, not the
# storage.config limit, which makes them unreliable in a containerised setup.

# Volume 1 — uses the full storage allocation from storage.config.
volume=1 scheme=http size=256
