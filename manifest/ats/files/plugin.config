#
# plugin.config
#
# Documentation:
#    https://docs.trafficserver.apache.org/en/latest/admin-guide/files/plugin.config.en.html
#
# Comments start with a '#' and continue to the end of the line
# Blank lines are ignored
#
# test-plugin.so arg1 arg2 arg3
#
# Example:
#inktomi/iwx/iwx.so
#inktomi/abuse/abuse.so etc/trafficserver/abuse.config
#inktomi/icx/icx.so etc/trafficserver/icx.config

header_rewrite.so /opt/etc/trafficserver/header_rewrite.config

# background_fetch.so: when ATS has a hit-stale object it serves the stale
# response to the client immediately (zero delay) and simultaneously issues a
# background request to the origin to refresh the cache entry. The client never
# waits for the origin — the revalidation happens out-of-band.
background_fetch.so
