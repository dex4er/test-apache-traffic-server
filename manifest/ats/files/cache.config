# Force a 60-second TTL for responses from the individual pod-0 origin.
# Overrides any Cache-Control headers the origin sends (or their absence).
# ttl-in-cache value must be an integer number of seconds (not "60s" or "0:1:0").

dest_domain=podinfo-0.podinfo.podinfo.svc.cluster.local ttl-in-cache=60

# Same fixed 60-second TTL for pod-1, keeping both pods' cache lifetimes in sync.

dest_domain=podinfo-1.podinfo.podinfo.svc.cluster.local ttl-in-cache=60

# The catch-all ClusterIP origin is excluded from disk cache. ATS requires a
# volume entry for Generic Hostnames in hosting.config or it disables disk cache
# entirely — there is no way to omit the catch-all volume assignment. Instead,
# we assign it to volume=1 in hosting.config but prohibit caching here with
# never-cache, so no responses from this origin are stored on disk or in RAM.

dest_domain=podinfo.podinfo.svc.cluster.local action=never-cache
