# Assign each per-pod origin to its dedicated logical volume (defined in volume.config)
# so that podinfo-0 and podinfo-1 cache entries are fully isolated on separate disks.
#
# ATS requires at least one volume to cover unmatched hostnames ("Generic Hostnames").
# If no catch-all entry exists, ATS disables disk cache entirely — omitting a hostname
# does NOT mean RAM-only caching. The ClusterIP service and any other host fall back
# to volume=1, sharing storage with podinfo-0.

hostname=podinfo-0.podinfo.podinfo.svc.cluster.local volume=1
hostname=podinfo-1.podinfo.podinfo.svc.cluster.local volume=2

# Catch-all: required by ATS — if no Generic Hostnames entry exists, ATS disables
# disk cache entirely. Assigning to volume=1 satisfies this requirement; actual
# caching for this origin is prevented by action=never-cache in cache.config.
hostname=* volume=1
