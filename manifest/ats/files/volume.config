# Logical cache volumes for per-origin cache isolation (used together with hosting.config).
# size is an explicit MB value matching each PVC's storage entry in storage.config.
# Alternatively size can be expressed as a percentage of total cache storage
# (all entries in storage.config summed), e.g. 50% of (128M+128M) = 128M each —
# but an absolute value is safer when PVC sizes are fixed and known.
# NOTE: this file is not currently mounted; kept for future use.

volume=1 scheme=http size=128M
volume=2 scheme=http size=128M
