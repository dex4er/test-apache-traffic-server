# Logical cache volumes for per-origin cache isolation (used together with hosting.config).
# Each volume maps 1:1 to a physical storage entry in storage.config:
#   volume=1 → /var/cache/ats/0 (ats-cache-0 PVC)
#   volume=2 → /var/cache/ats/1 (ats-cache-1 PVC)
# size= accepts an absolute value in megabytes (integer only, no suffix).
# Must be strictly less than the corresponding storage.config entry (256M)
# to leave room for ATS stripe headers and cache metadata.
#
# WARNING: Any change to this file (volume count, size, or scheme) causes ATS to
# invalidate and wipe the entire disk cache on next startup ("Clearing Disk" in
# diags.log). All cached content is lost. Plan changes accordingly.

volume=1 scheme=http size=128
volume=2 scheme=http size=128
