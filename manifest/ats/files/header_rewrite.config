# If All-Cache is already present (set by an inner remap), append the current
# hop's cache status so the header accumulates all cache decisions, e.g.
# "hit-fresh, miss" when two remap rules are traversed.

cond %{SEND_RESPONSE_HDR_HOOK} [AND]
cond %{HEADER:All-Cache} ="" [NOT]
  set-header All-Cache "%{HEADER:All-Cache}, %{CACHE}"

# If All-Cache is absent (first or only hop), initialise it with the current
# cache status: miss, hit-fresh, hit-stale, or skipped.

cond %{SEND_RESPONSE_HDR_HOOK} [AND]
cond %{HEADER:All-Cache} =""
  set-header All-Cache %{CACHE}
