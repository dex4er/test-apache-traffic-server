# Two separate cache storage directories, each backed by its own PVC
# (ats-cache-0 and ats-cache-1 defined in statefulset.yaml volumeClaimTemplates).
# Each entry maps to one logical volume in volume.config (volume=1 and volume=2),
# and hosting.config pins podinfo-0 to volume=1 and podinfo-1 to volume=2,
# ensuring complete disk cache isolation between the two origins under test.
# Storage is set to 256M (larger than the 128M volume size in volume.config)
# to leave room for ATS stripe metadata and bookkeeping data.

/var/cache/ats/0 256M volume=1
/var/cache/ats/1 256M volume=2
