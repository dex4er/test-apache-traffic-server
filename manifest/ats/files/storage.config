# Two separate cache storage directories, each backed by its own PVC
# (ats-cache-0 and ats-cache-1 defined in statefulset.yaml volumeClaimTemplates).
# Keeping them on separate volumes allows future use of volume.config / hosting.config
# to pin podinfo-0 traffic to stripe 1 and podinfo-1 traffic to stripe 2,
# ensuring complete cache isolation between the two origins under test.

/var/cache/ats/0 128M
/var/cache/ats/1 128M
