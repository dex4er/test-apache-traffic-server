# Route /podinfo-0 and /podinfo-1 to specific StatefulSet pods via the headless
# service DNS (podinfo-0.podinfo… / podinfo-1.podinfo…), which resolves directly
# to the individual pod IP without load-balancing. This allows per-pod cache
# separation in storage.config. These rules must appear before the catch-all.

map /podinfo-0 http://podinfo-0.podinfo.podinfo.svc.cluster.local:9898/
map /podinfo-1 http://podinfo-1.podinfo.podinfo.svc.cluster.local:9898/

# Catch-all: forwards everything else to the regular ClusterIP service, which
# round-robin load-balances across the same two pod instances as the rules above.
# Must be last — ATS matches rules top-to-bottom and stops at the first match.

map / http://podinfo.podinfo.svc.cluster.local:9898/
